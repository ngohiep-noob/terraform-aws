project_name       = "tf-dev"
aws_region         = "ap-southeast-1"
# Leave this unset when using aws login / SSO-backed credentials.
# Set it only if you want Terraform to use a named shared profile.
aws_profile        = null
vpc_cidr           = "10.20.0.0/16"
public_subnet_cidr = "10.20.1.0/24"

resource_tags = {
  Environment = "test-dev"
  Owner       = "your-name"
  ManagedBy   = "terraform"
}
